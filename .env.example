# usher in making — 環境変数サンプル
# Vercel の Project → Settings → Environment Variables に設定します。
# ローカル開発では `vercel env pull .env.local` で取得するか、このファイルを
# .env.local にコピーして値を入れてください（.env* は git にコミットしない）。

# ─── メール通知（Resend / 任意だが本番推奨）───────────────────────────────
# https://resend.com で取得する API キー（無料枠あり）。未設定でもフォーム受付は成功する。
RESEND_API_KEY=

# お問い合わせ・予約の通知先メールアドレス（受信したいスタジオの宛先）。
CONTACT_TO=studio@example.com

# 差出人。Resend で検証済みのドメイン/アドレスを推奨。未設定なら resend のサンドボックス。
CONTACT_FROM=usher in making <onboarding@resend.dev>

# 予約通知の宛先・差出人（任意。未設定時は CONTACT_TO / 既定の差出人にフォールバック）。
RESERVE_TO=
RESERVE_FROM=

# 1日に受け付ける予約上限組数（既定 1 = 1日1組／同日重複不可）。
RESERVE_DAILY_CAPACITY=1

# ─── 管理画面（/admin.html）────────────────────────────────────────────────
# 管理画面のログインパスワード。未設定だと安全のためログイン不可。長くランダムな値を推奨。
ADMIN_PASSWORD=

# トークン署名用の秘密鍵（任意・本番推奨）。未設定なら ADMIN_PASSWORD を流用する。
# ログインパスワードとは別の高エントロピー値にすると、トークン偽造耐性が上がる。
#   例: openssl rand -hex 32
ADMIN_TOKEN_SECRET=

# 公開（サイト再構築）に使う Vercel Deploy Hook の URL（任意）。
# Vercel → Settings → Git → Deploy Hooks で作成。未設定なら[発行]は 501 を返すだけ。
DEPLOY_HOOK_URL=

# ─── ブログ翻訳（Anthropic Claude / ブログ自動翻訳に使用・任意）─────────────
# 管理画面のブログ編集で［日本語/英語 번역］を使うと、韓国語原文を翻訳する。
# 未設定なら翻訳ボタンは 501 を返す（記事の手動入力は可能）。
#   https://console.anthropic.com で取得。
ANTHROPIC_API_KEY=
# 翻訳モデル（任意・既定 claude-haiku-4-5）。品質重視なら claude-sonnet-4-6 等。
ANTHROPIC_MODEL=claude-haiku-4-5

# （補足）公開 POST（お問い合わせ/予約）には同一IP 5回/分の簡易レート制限が
#   組み込み済み（KV 利用時のみ有効）。追加設定は不要。

# ─── データ永続化（Vercel KV / 本番必須）──────────────────────────────────
# 本番（VERCEL_ENV=production）では KV 必須。未設定だと書き込み時にエラーにして
# データ消失（/tmp 揮発）を防ぐ。両方そろうと api/_lib/store.js が自動で KV を使う。
# 両方が設定されていれば api/_lib/store.js は自動で KV を使う（無ければ /tmp JSON）。
# Vercel ダッシュボードで KV ストアを作成・プロジェクトに接続すると自動で注入される。
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 読み取り専用トークン（KV 作成時に併せて発行される。本アプリでは未使用でも可）。
KV_REST_API_READ_ONLY_TOKEN=
