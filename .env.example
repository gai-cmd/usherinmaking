# usher in making — 環境変数サンプル
# Vercel の Project → Settings → Environment Variables に設定します。
# ローカル開発では `vercel env pull .env.local` で取得するか、このファイルを
# .env.local にコピーして値を入れてください（.env* は git にコミットしない）。

# ─── メール通知（Resend / 任意だが本番推奨）───────────────────────────────
# https://resend.com で取得する API キー（無料枠あり）。未設定でもフォーム受付は成功する。
RESEND_API_KEY=

# お問い合わせ・予約の通知先メールアドレス（受信したいスタジオの宛先）。
CONTACT_TO=studio@example.com

# 差出人。Resend で検証済みのドメイン/アドレスを推奨。未設定なら resend のサンドボックス。
CONTACT_FROM=usher in making <onboarding@resend.dev>

# 予約通知の宛先・差出人（任意。未設定時は CONTACT_TO / 既定の差出人にフォールバック）。
RESERVE_TO=
RESERVE_FROM=

# 1日に受け付ける予約上限組数（既定 1 = 1日1組／同日重複不可）。
RESERVE_DAILY_CAPACITY=1

# ─── 管理画面（/admin.html）────────────────────────────────────────────────
# 管理画面のログインパスワード。未設定だと安全のためログイン不可。長くランダムな値を推奨。
ADMIN_PASSWORD=

# ─── データ永続化（Vercel KV / 本番推奨）──────────────────────────────────
# 両方が設定されていれば api/_lib/store.js は自動で KV を使う（無ければ /tmp JSON）。
# Vercel ダッシュボードで KV ストアを作成・プロジェクトに接続すると自動で注入される。
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 読み取り専用トークン（KV 作成時に併せて発行される。本アプリでは未使用でも可）。
KV_REST_API_READ_ONLY_TOKEN=
